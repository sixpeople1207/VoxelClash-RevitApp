<Window x:Class="myApp.UI.UIDbInformation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:myApp.UI"
        mc:Ignorable="d"
        Title="UIDbInformation" Height="474" Width="838">
    <Grid Height="464" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="461.04"/>
            <RowDefinition Height="2.96"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dataGridFindResult" 
                   AutoGenerateColumns="True"
          EnableRowVirtualization="True"
                  Margin="15,68,0,44" RenderTransformOrigin="0.5,0.5" 
                  HorizontalAlignment="Left" Width="508" 
                  SelectionChanged="dataGridFindResult_SelectionChanged">

        </DataGrid>
        <Label x:Name="labelModel" Content="Table Name : " HorizontalAlignment="Left" Margin="15,37,0,0" VerticalAlignment="Top" Height="22" Width="82"/>
        <Button x:Name="btnModeling" Content="Drawing" HorizontalAlignment="Left" Margin="437,39,0,0" VerticalAlignment="Top" Background="#FF909090" FontWeight="Bold" Foreground="White" Width="86" Click="btnModeling_Click" Height="22"/>
        <Label x:Name="labelPath" Content="Path : " HorizontalAlignment="Left" Margin="15,10,0,0" VerticalAlignment="Top" Height="22" Width="35"/>
        <Label x:Name="labelStatus" Content="            " HorizontalAlignment="Left" Margin="60,417,0,0" VerticalAlignment="Top" Width="448" Height="22" />
        <TextBox x:Name="textBoxDBPath" HorizontalAlignment="Left" Margin="56,8,0,428" TextWrapping="Wrap" Text="" Width="375"/>
        <Label x:Name="_labelStatus" Content="status : " HorizontalAlignment="Left" Margin="15,417,0,0" VerticalAlignment="Top" Height="22" Width="43" />
        <ComboBox x:Name="comboBoxTbList" HorizontalAlignment="Left" Margin="97,39,0,0" VerticalAlignment="Top" Width="334" SelectionChanged="comboBoxTbList_SelectionChanged"/>
        <Button x:Name="btnDBConnect" Content="Connect" HorizontalAlignment="Left" Margin="437,10,0,0" VerticalAlignment="Top" Width="86" Click="btnDBConnect_Click"/>
        <TextBox x:Name="textBoxLog" HorizontalAlignment="Left" Margin="528,68,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto" Width="300" Height="349"/>
        <TextBox x:Name="textBoxShift" HorizontalAlignment="Left" Margin="528,39,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Window>
